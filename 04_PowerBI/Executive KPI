Average Profit per Order = 
DIVIDE(
    [Total Profit],
    [Total Orders]
)

Average Quantity per Order = 
DIVIDE(
    [Total Quantity],
    [Total Orders]
)

Cost Ratio % = 
DIVIDE(
    [Total Cost],
    [Total Revenue],
    0
)

Discount to Revenue % = 
DIVIDE(
    [Total Discount],
    [Gross Revenue],
    0
)

Profit per Product = 
DIVIDE(
    [Total Profit],
    [Total Products]
)

Revenue per Product = 
DIVIDE(
    [Total Revenue],
    [Total Products]
)
